# ── Server ─────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────
# Local (development):
MONGO_URI=mongodb+srv://kartikgour23_db_user:kartik2004@cluster1.jwrwpeb.mongodb.net/?appName=Cluster1
# Production (MongoDB Atlas - FREE):
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/nexus

# ── Auth ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_EXPIRE=30d

# ── URLs ───────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
# Production: CLIENT_URL=https://your-app.vercel.app

# ── Email (Gmail SMTP) ─────────────────────────────────────────────
# Setup Gmail App Password:
# 1. Enable 2FA on your Gmail account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a 16-char app password (NOT your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=kartikgour745@gmail.com
EMAIL_PASS=rwqeknzehnsehwxa
EMAIL_FROM_NAME=Nexus Platform

# ── Razorpay (Indian Payment Gateway) ─────────────────────────────
# Create account at https://razorpay.com (free, instant activation for Indian businesses)
# Get Test keys from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── India / Localization ───────────────────────────────────────────
CURRENCY=INR
COUNTRY=IN
PLATFORM_NAME=Nexus
PLATFORM_TAGLINE=Where Startups Meet Corporates

# ── Razorpay Plan IDs (Optional - for subscription billing) ────────
# If you want monthly subscriptions instead of one-time orders,
# create Plans in Razorpay Dashboard > Subscriptions > Plans
# RAZORPAY_PLAN_STARTER=plan_xxx
# RAZORPAY_PLAN_PROFESSIONAL=plan_xxx
# RAZORPAY_PLAN_ENTERPRISE=plan_xxx
